<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚜ Stars of Destiny"
        android:textColor="#D9A636"
        android:textStyle="bold"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/widget_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="0 / 540"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="24sp" />

    <ProgressBar
        android:id="@+id/widget_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="8dp"
        android:max="540"
        android:progress="0"
        android:progressTint="#D9A636" />

    <TextView
        android:id="@+id/widget_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Suikoden Codex"
        android:textColor="#9AA0B5"
        android:textSize="11sp" />
</LinearLayout>

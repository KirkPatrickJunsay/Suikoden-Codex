<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SuikodenCodex"
             x:Class="SuikodenCodex.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <local:InvertedBoolConverter x:Key="InvertedBool" />
            <local:StringNotEmptyConverter x:Key="StringNotEmpty" />
            <local:FavoriteGlyphConverter x:Key="FavGlyph" />
            <local:ChevronConverter x:Key="Chevron" />
            <local:BoolToColorConverter x:Key="BoolToColor" />
            <local:HexToColorConverter x:Key="HexToColor" />
            <local:QuizStateToColorConverter x:Key="QuizStateToColor" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

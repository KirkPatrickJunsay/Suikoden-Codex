<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SuikodenCodex.Pages.CardDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SuikodenCodex.ViewModels"
    xmlns:models="clr-namespace:SuikodenCodex.Models"
    x:DataType="vm:CardDetailViewModel"
    x:Name="CardRoot"
    Title="{Binding Card.Name}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Share" Clicked="OnShare" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16" BindingContext="{Binding Card}" x:DataType="models:CardEntry">

            <!-- card art (tap to maximize) inside a branded share frame -->
            <VerticalStackLayout x:Name="ShareFrame" IsVisible="{Binding HasImage}" Spacing="8"
                                 BackgroundColor="{StaticResource IndigoDeep}" Padding="16" HorizontalOptions="Center">
                <Border HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 12" Stroke="#22808080" BackgroundColor="White" Padding="8">
                    <Grid>
                        <Image Source="{Binding ImageName}" Aspect="AspectFit" HeightRequest="300" />
                        <Label Text="⛶" FontSize="16" TextColor="#99000000" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,4,2" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding BindingContext.OpenImageCommand, Source={x:Reference CardRoot}}" />
                    </Border.GestureRecognizers>
                </Border>
                <Label Text="⚜ Suikoden Codex · Card Stories" FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource Gold}" HorizontalOptions="Center" />
            </VerticalStackLayout>
            <Label Text="🎴" FontSize="48" IsVisible="{Binding HasImage, Converter={StaticResource InvertedBool}}"
                   HorizontalOptions="Center" />

            <VerticalStackLayout Spacing="2">
                <Label Text="{Binding Name}" FontSize="24" FontAttributes="Bold" />
                <Label Text="{Binding OriginalName}" FontSize="15" Opacity="0.7" />
                <Label Text="{Binding Reading}" FontSize="13" Opacity="0.5" FontAttributes="Italic" />
            </VerticalStackLayout>

            <Border StrokeShape="RoundRectangle 14" Padding="12,5" HorizontalOptions="Start"
                    BackgroundColor="#2E8B8B">
                <Label Text="Card Stories" TextColor="White" FontSize="12" FontAttributes="Bold" />
            </Border>

            <!-- facts -->
            <Border StrokeShape="RoundRectangle 8" Stroke="#22808080" Padding="14,12">
                <VerticalStackLayout Spacing="6">
                    <Grid ColumnDefinitions="104,*" ColumnSpacing="10">
                        <Label Text="Card no." FontSize="13" FontAttributes="Bold" Opacity="0.55" />
                        <Label Grid.Column="1" Text="{Binding NumberLabel}" FontSize="13" />
                    </Grid>
                    <Grid ColumnDefinitions="104,*" ColumnSpacing="10">
                        <Label Text="Type" FontSize="13" FontAttributes="Bold" Opacity="0.55" />
                        <Label Grid.Column="1" Text="{Binding Type}" FontSize="13" />
                    </Grid>
                    <Grid ColumnDefinitions="104,*" ColumnSpacing="10">
                        <Label Text="Camp" FontSize="13" FontAttributes="Bold" Opacity="0.55" />
                        <Label Grid.Column="1" Text="{Binding Camp}" FontSize="13" />
                    </Grid>
                    <Grid ColumnDefinitions="104,*" ColumnSpacing="10">
                        <Label Text="Pack" FontSize="13" FontAttributes="Bold" Opacity="0.55" />
                        <Label Grid.Column="1" Text="{Binding Pack}" FontSize="13" />
                    </Grid>
                    <Grid ColumnDefinitions="104,*" ColumnSpacing="10" IsVisible="{Binding HasArtist}">
                        <Label Text="Artist" FontSize="13" FontAttributes="Bold" Opacity="0.55" />
                        <Label Grid.Column="1" Text="{Binding Artist}" FontSize="13" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- effect -->
            <Border IsVisible="{Binding HasEffectEn}" StrokeShape="RoundRectangle 8"
                    BackgroundColor="#152E8B8B" Stroke="#2E8B8B" Padding="14,12">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Card effect" FontSize="13" FontAttributes="Bold" TextColor="#5BC8C8" />
                    <Label Text="{Binding EffectEn}" FontSize="14" LineHeight="1.4" />
                    <Label Text="{Binding EffectJp}" FontSize="12" Opacity="0.55" IsVisible="{Binding HasEffectJp}" />
                </VerticalStackLayout>
            </Border>

            <!-- attribution -->
            <VerticalStackLayout Spacing="2" Margin="0,8,0,0">
                <BoxView HeightRequest="1" Color="#33808080" Margin="0,0,0,8" />
                <Label Text="Genso Suikoden Card Stories · Source: Gensopedia (gensopedia.org)" FontSize="11" Opacity="0.5" />
                <Label Text="Card art © Gensopedia &amp; Konami · Suikoden © Konami" FontSize="11" Opacity="0.5" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

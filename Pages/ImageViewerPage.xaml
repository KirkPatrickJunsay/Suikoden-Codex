<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SuikodenCodex.Pages.ImageViewerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#0B0E1A">

    <Grid>
        <Image x:Name="Img" Aspect="AspectFit" Margin="6">
            <Image.GestureRecognizers>
                <PinchGestureRecognizer PinchUpdated="OnPinch" />
                <PanGestureRecognizer PanUpdated="OnPan" />
                <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnDoubleTap" />
            </Image.GestureRecognizers>
        </Image>

        <Border StrokeShape="RoundRectangle 18" BackgroundColor="#88000000" Padding="2"
                WidthRequest="40" HeightRequest="40"
                HorizontalOptions="End" VerticalOptions="Start" Margin="0,12,16,0">
            <Label Text="✕" TextColor="White" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTapClose" />
            </Border.GestureRecognizers>
        </Border>

        <Label Text="Pinch or double-tap to zoom · ✕ to close" TextColor="#99FFFFFF" FontSize="12"
               HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,24" />
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SuikodenCodex.Pages.EntryListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SuikodenCodex.ViewModels"
    xmlns:models="clr-namespace:SuikodenCodex.Models"
    x:DataType="vm:EntryListViewModel"
    Title="{Binding Title}">

    <Grid>
        <CollectionView ItemsSource="{Binding Entries}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CodexEntry">
                    <Grid Padding="16,10" ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border WidthRequest="50" HeightRequest="50" Padding="0" VerticalOptions="Center"
                                StrokeShape="RoundRectangle 10" Stroke="#22808080" BackgroundColor="Transparent">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding HasImage}" Value="True">
                                    <Setter Property="BackgroundColor" Value="White" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Image Source="{Binding ImageName}" Aspect="AspectFill" IsVisible="{Binding HasImage}" />
                                <Label Text="{Binding Glyph}" FontSize="24" IsVisible="{Binding ShowGlyph}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold"
                                   MaxLines="1" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Subtitle}" FontSize="12" Opacity="0.6"
                                   MaxLines="1" LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EntryListViewModel}}, Path=OpenEntryCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Text="{Binding EmptyMessage}"
               IsVisible="{Binding IsEmpty}"
               HorizontalOptions="Center" VerticalOptions="Center"
               HorizontalTextAlignment="Center" Opacity="0.6" />
    </Grid>
</ContentPage>

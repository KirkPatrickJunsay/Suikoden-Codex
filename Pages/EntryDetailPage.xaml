<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SuikodenCodex.Pages.EntryDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SuikodenCodex.ViewModels"
    xmlns:models="clr-namespace:SuikodenCodex.Models"
    x:DataType="vm:EntryDetailViewModel"
    Title="{Binding Entry.Name}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Share" Clicked="OnShare" />
        <ToolbarItem Text="{Binding IsFavorite, Converter={StaticResource FavGlyph}}"
                     Command="{Binding ToggleFavoriteCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Header (also the share frame) -->
            <VerticalStackLayout x:Name="ShareFrame" Spacing="10"
                                 BackgroundColor="{StaticResource IndigoDeep}" Padding="16">
            <VerticalStackLayout Spacing="6">
                <Border IsVisible="{Binding Entry.HasImage}" HorizontalOptions="Start"
                        StrokeShape="RoundRectangle 12" Stroke="#22808080"
                        BackgroundColor="White" Padding="10">
                    <Grid>
                        <Image Source="{Binding Entry.ImageName}" Aspect="AspectFit"
                               HeightRequest="190" MaximumWidthRequest="240" />
                        <Label Text="⛶" FontSize="16" TextColor="#99000000"
                               HorizontalOptions="End" VerticalOptions="End" Margin="0,0,2,0" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenImageCommand}" />
                    </Border.GestureRecognizers>
                </Border>
                <Label Text="{Binding Entry.Glyph}" FontSize="40" IsVisible="{Binding Entry.ShowGlyph}" />
                <Label Text="{Binding Entry.Name}" FontSize="26" FontAttributes="Bold" />
                <Label Text="{Binding Entry.OriginalName}" FontSize="16" Opacity="0.7" />
                <Label Text="{Binding Entry.Reading}" FontSize="13" Opacity="0.5" FontAttributes="Italic" />
            </VerticalStackLayout>

            <!-- Category / game chips -->
            <HorizontalStackLayout Spacing="8">
                <Border StrokeShape="RoundRectangle 14" Padding="12,5"
                        BackgroundColor="{Binding Entry.AccentColor, Converter={StaticResource HexToColor}}">
                    <Label Text="{Binding Entry.CategoryDisplay}" TextColor="White" FontSize="12" FontAttributes="Bold" />
                </Border>
                <Border StrokeShape="RoundRectangle 14" Padding="12,5" Stroke="#80808080"
                        IsVisible="{Binding Entry.Game, Converter={StaticResource StringNotEmpty}}">
                    <Label Text="{Binding Entry.Game}" FontSize="12" />
                </Border>
            </HorizontalStackLayout>

            <Label Text="{Binding Entry.Subtype}" FontSize="13" FontAttributes="Bold" Opacity="0.75"
                   IsVisible="{Binding Entry.Subtype, Converter={StaticResource StringNotEmpty}}" />

            <Label Text="⚜ Suikoden Codex" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource Gold}" Margin="0,2,0,0" />
            </VerticalStackLayout>

            <!-- Profile facts (Star, Origin, Race, Age…) -->
            <Border IsVisible="{Binding Entry.HasFacts}" StrokeShape="RoundRectangle 8"
                    Stroke="#22808080" Padding="14,12">
                <VerticalStackLayout Spacing="6" BindableLayout.ItemsSource="{Binding Entry.Facts}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:Fact">
                            <Grid ColumnDefinitions="104,*" ColumnSpacing="10">
                                <Label Text="{Binding Label}" FontSize="13" FontAttributes="Bold" Opacity="0.55" />
                                <Label Grid.Column="1" Text="{Binding Value}" FontSize="13" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Border>

            <!-- How to recruit -->
            <Border IsVisible="{Binding Entry.HasRecruitment}" StrokeShape="RoundRectangle 8"
                    BackgroundColor="#152E7D32" Stroke="#2E7D32" Padding="14,12">
                <VerticalStackLayout Spacing="3">
                    <Label Text="🤝 How to recruit" FontSize="13" FontAttributes="Bold" TextColor="#4CAF50" />
                    <Label Text="{Binding Entry.Recruitment}" FontSize="14" LineHeight="1.35" />
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="1" Color="#33808080" />

            <!-- Description (hidden behind a tap when spoiler-safe mode is on) -->
            <Label Text="{Binding Entry.Description}" FontSize="15" LineHeight="1.4"
                   IsVisible="{Binding ShowDescription}" />
            <Border IsVisible="{Binding DescriptionHidden}"
                    StrokeShape="RoundRectangle 8" BackgroundColor="#15808080" Padding="16">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="⚠ Spoilers hidden" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="Tap to reveal description" FontSize="12" Opacity="0.7" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding RevealDescriptionCommand}" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Flavor quote -->
            <Border IsVisible="{Binding Entry.Quote, Converter={StaticResource StringNotEmpty}}"
                    StrokeShape="RoundRectangle 8" BackgroundColor="#15808080" Padding="14">
                <Label Text="{Binding Entry.Quote}" FontAttributes="Italic" FontSize="14" />
            </Border>

            <!-- Collapsible profile sections (Appearance, Personality, Story, Trivia) -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding HasSections}"
                                 BindableLayout.ItemsSource="{Binding Sections}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:SectionVM">
                        <Border StrokeShape="RoundRectangle 8" Stroke="#22808080">
                            <VerticalStackLayout>
                                <Grid ColumnDefinitions="*,Auto" Padding="14,12">
                                    <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold" />
                                    <Label Grid.Column="1" FontSize="15" Opacity="0.6"
                                           Text="{Binding IsExpanded, Converter={StaticResource Chevron}}" />
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                                <Label Text="{Binding Body}" FontSize="14" LineHeight="1.4"
                                       Padding="14,0,14,12" IsVisible="{Binding IsExpanded}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Trivia / Did you know? -->
            <Border IsVisible="{Binding Entry.HasTrivia}" StrokeShape="RoundRectangle 8"
                    BackgroundColor="#15C28A1E" Stroke="#C28A1E" Padding="14,12">
                <VerticalStackLayout Spacing="3">
                    <Label Text="💡 Did you know?" FontSize="13" FontAttributes="Bold" TextColor="#E0B341" />
                    <Label Text="{Binding Entry.Trivia}" FontSize="14" LineHeight="1.4" />
                </VerticalStackLayout>
            </Border>

            <!-- Unite (combo) attacks -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding HasUnites}">
                <BoxView HeightRequest="1" Color="#33808080" />
                <Label Text="{Binding UnitesTitle, StringFormat='⚔ {0}'}" FontAttributes="Bold" FontSize="16"
                       TextColor="{StaticResource Gold}" />
                <CollectionView ItemsSource="{Binding Unites}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CodexEntry">
                            <Grid Padding="0,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border WidthRequest="44" HeightRequest="44" Padding="0" VerticalOptions="Center"
                                        StrokeShape="RoundRectangle 9" Stroke="#44D9A636" BackgroundColor="#1AD9A636">
                                    <Grid>
                                        <Image Source="{Binding ImageName}" Aspect="AspectFill" IsVisible="{Binding HasImage}" />
                                        <Label Text="⚔️" FontSize="18" IsVisible="{Binding ShowGlyph}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontSize="15" FontAttributes="Bold" />
                                    <Label Text="{Binding Game}" FontSize="12" Opacity="0.6" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="20" Opacity="0.4" VerticalOptions="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EntryDetailViewModel}}, Path=OpenRelatedCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Related entries (cross-references) -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding HasRelated}">
                <BoxView HeightRequest="1" Color="#33808080" />
                <Label Text="Related entries" FontAttributes="Bold" FontSize="16" />
                <CollectionView ItemsSource="{Binding RelatedEntries}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CodexEntry">
                            <Grid Padding="0,8" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border WidthRequest="44" HeightRequest="44" Padding="0" VerticalOptions="Center"
                                        StrokeShape="RoundRectangle 9" Stroke="#22808080" BackgroundColor="Transparent">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding HasImage}" Value="True">
                                            <Setter Property="BackgroundColor" Value="White" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Grid>
                                        <Image Source="{Binding ImageName}" Aspect="AspectFill" IsVisible="{Binding HasImage}" />
                                        <Label Text="{Binding Glyph}" FontSize="20" IsVisible="{Binding ShowGlyph}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontSize="15" FontAttributes="Bold" />
                                    <Label Text="{Binding CategoryDisplay}" FontSize="12" Opacity="0.6" />
                                </VerticalStackLayout>
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EntryDetailViewModel}}, Path=OpenRelatedCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Attribution -->
            <VerticalStackLayout Spacing="2" Margin="0,8,0,0">
                <BoxView HeightRequest="1" Color="#33808080" Margin="0,0,0,8" />
                <Label Text="Source: Gensopedia (gensopedia.org)" FontSize="11" Opacity="0.5" />
                <Label Text="Images © Gensopedia &amp; Konami · Suikoden © Konami" FontSize="11" Opacity="0.5" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
